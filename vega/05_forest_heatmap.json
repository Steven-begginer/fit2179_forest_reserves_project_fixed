{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/forest_reserve_state.csv"
  },
  "title": {
    "text": "Forest reserve area across states and years",
    "subtitle": "A heatmap reveals long-term state-level patterns."
  },
  "mark": {
    "type": "rect"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null
    },
    "color": {
      "field": "area",
      "type": "quantitative",
      "title": "Area (ha)",
      "scale": {
        "scheme": "greens"
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "year",
        "type": "ordinal"
      },
      {
        "field": "area",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Area (ha)"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "gridColor": "#e8edf0",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  },
  "transform": [
    {
      "filter": "isValid(datum.area) && datum.area > 0"
    }
  ]
}