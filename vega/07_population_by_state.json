{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/population.csv"
  },
  "transform": [
    {
      "filter": "datum.state != 'Malaysia'"
    },
    {
      "calculate": "datum.pop / 1000000",
      "as": "population_million"
    }
  ],
  "title": {
    "text": "Population context by state",
    "subtitle": "Forest reserve pressure is easier to understand when population is visible."
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "population_million",
      "type": "quantitative",
      "title": "Population (million people)"
    },
    "color": {
      "field": "population_million",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "pop",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Population"
      },
      {
        "field": "pop_18",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Age 18+"
      },
      {
        "field": "pop_60",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Age 60+"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "gridColor": "#e8edf0",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  }
}