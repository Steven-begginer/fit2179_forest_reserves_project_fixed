{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/forest_reserve_state.csv"
  },
  "transform": [
    {
      "filter": "datum.year == 2021"
    }
  ],
  "title": {
    "text": "Which states held the most forest reserve area in 2021?",
    "subtitle": "Ranked by forest reserve area in hectares."
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "area",
      "type": "quantitative",
      "title": "Forest reserve area (ha)"
    },
    "color": {
      "field": "area",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "scheme": "greens"
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "area",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Area (ha)"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "gridColor": "#e8edf0",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  }
}