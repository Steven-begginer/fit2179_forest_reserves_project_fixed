{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/state_forest_slope.csv"
  },
  "title": {
    "text": "State forest reserves: 2003 compared with 2021",
    "subtitle": "Each line shows how one state moved between the first and latest year."
  },
  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 70
    },
    "strokeWidth": 2
  },
  "encoding": {
    "x": {
      "field": "period",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "area_million_ha",
      "type": "quantitative",
      "title": "Forest reserve area (million ha)",
      "scale": {
        "zero": false
      }
    },
    "color": {
      "field": "direction",
      "type": "nominal",
      "scale": {
        "domain": [
          "Decrease",
          "Increase"
        ],
        "range": [
          "#d97706",
          "#15803d"
        ]
      }
    },
    "detail": {
      "field": "state",
      "type": "nominal"
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "year",
        "type": "ordinal"
      },
      {
        "field": "area",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Area (ha)"
      },
      {
        "field": "direction",
        "type": "nominal"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "gridColor": "#e8edf0",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  }
}