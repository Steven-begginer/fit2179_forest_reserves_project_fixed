{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/state_forest_change.csv"
  },
  "title": {
    "text": "Forest reserve change by state, 2003–2021",
    "subtitle": "Positive values indicate gains; negative values indicate losses."
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "x",
      "title": null
    },
    "x": {
      "field": "change_area",
      "type": "quantitative",
      "title": "Change in forest reserve area (ha)"
    },
    "color": {
      "field": "direction",
      "type": "nominal",
      "scale": {
        "domain": [
          "Decrease",
          "Increase"
        ],
        "range": [
          "#d97706",
          "#15803d"
        ]
      },
      "title": "Direction"
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "area_2003",
        "type": "quantitative",
        "format": ",.0f",
        "title": "2003 area (ha)"
      },
      {
        "field": "area_2021",
        "type": "quantitative",
        "format": ",.0f",
        "title": "2021 area (ha)"
      },
      {
        "field": "change_area",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Change (ha)"
      },
      {
        "field": "change_percent",
        "type": "quantitative",
        "format": ".1f",
        "title": "Change (%)"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "gridColor": "#e8edf0",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  }
}