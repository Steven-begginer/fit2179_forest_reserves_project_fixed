{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 430,
  "data": {
    "url": "data/forest_population_2021.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum.forest_ha_per_1000_people)",
      "as": "forest_per_1000_num"
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank_desc"
        }
      ],
      "sort": [
        {
          "field": "forest_per_1000_num",
          "order": "descending"
        }
      ]
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank_asc"
        }
      ],
      "sort": [
        {
          "field": "forest_per_1000_num",
          "order": "ascending"
        }
      ]
    },
    {
      "calculate": "datum.rank_desc == 1 ? 'Highest' : datum.rank_asc == 1 ? 'Lowest' : 'Other'",
      "as": "bar_highlight"
    }
  ],
  "title": {
    "text": "Forest reserve area per 1,000 people"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "forest_ha_per_1000_people",
      "type": "quantitative",
      "title": "Forest reserve area (ha per 1,000 people)"
    },
    "color": {
      "field": "bar_highlight",
      "type": "nominal",
      "legend": null,
      "scale": {
        "domain": [
          "Other",
          "Highest",
          "Lowest"
        ],
        "range": [
          "#60a5fa",
          "#1d4ed8",
          "#dbeafe"
        ]
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "forest_ha_per_1000_people",
        "type": "quantitative",
        "format": ".1f",
        "title": "ha per 1,000 people"
      },
      {
        "field": "forest_area_2021",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Forest reserve area (ha)"
      },
      {
        "field": "pop",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Population"
      },
      {
        "field": "bar_highlight",
        "type": "nominal",
        "title": "Highlight"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "gridColor": "#e8edf0",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a"
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 18,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  }
}