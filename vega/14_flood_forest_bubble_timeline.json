{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 500,
  "projection": {
    "type": "conicEqualArea",
    "parallels": [1, 7],
    "rotate": [-102.2, 0, 0],
    "center": [0, 4],
    "scale": 4700
  },
  "title": {
    "text": "District Flood Frequency in High-Flood States",
    "subtitle": [
      "Selected states are highlighted on the map.",
      "Each district uses a distinct colour; larger dots mean flooding was recorded in more years between 2003 and 2010."
    ]
  },
  "layer": [
    {
      "data": { "sphere": true },
      "mark": { "type": "geoshape", "fill": "#dbeafe", "stroke": null }
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": { "type": "topojson", "feature": "countries" }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eef2f7",
        "stroke": "#cbd5e1",
        "strokeWidth": 0.4
      }
    },
    {
      "data": {
        "url": "data/malaysia_states.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "transform": [
        {
          "calculate": "replace(datum.properties.name, 'WP K Lumpur', 'W.P. Kuala Lumpur')",
          "as": "state_name"
        },
        {
          "calculate": "datum.state_name == 'Pahang' || datum.state_name == 'Kedah' || datum.state_name == 'Negeri Sembilan' || datum.state_name == 'Johor' || datum.state_name == 'Terengganu' ? 'Selected high-flood state' : 'Other state'",
          "as": "state_group"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.9
      },
      "encoding": {
        "color": {
          "field": "state_group",
          "type": "nominal",
          "title": "State group",
          "scale": {
            "domain": ["Selected high-flood state", "Other state"],
            "range": ["#93C5FD", "#E5E7EB"]
          },
          "legend": { "orient": "bottom" }
        },
        "tooltip": [
          { "field": "state_name", "type": "nominal", "title": "State" },
          { "field": "state_group", "type": "nominal", "title": "Group" }
        ]
      }
    },
    {
      "data": { "url": "data/district_flood_frequency_map.csv" },
      "mark": {
        "type": "circle",
        "filled": true,
        "opacity": 0.86,
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "size": {
          "field": "flood_years",
          "type": "quantitative",
          "title": "Flood years recorded",
          "scale": { "domain": [1, 7], "range": [25, 360] },
          "legend": { "orient": "bottom", "values": [1, 3, 5, 7] }
        },
        "color": {
          "field": "district",
          "type": "nominal",
          "title": "District",
          "scale": {
            "domain": [
              "Batu Pahat",
              "Johor Bahru",
              "Kluang",
              "Kota Tinggi",
              "Muar",
              "Segamat",
              "Baling",
              "Kota Setar",
              "Kuala Muda",
              "Kubang Pasu",
              "Kulim",
              "Port Dickson",
              "Seremban",
              "Jerantut",
              "Kuantan",
              "Maran",
              "Pekan",
              "Rompin",
              "Temerloh",
              "Besut",
              "Dungun",
              "Hulu Terengganu",
              "Kemaman",
              "Kuala Terengganu",
              "Marang",
              "Setiu"
            ],
            "range": [
              "#1D4ED8",
              "#F59E0B",
              "#7C3AED",
              "#0EA5E9",
              "#A855F7",
              "#8B5CF6",
              "#38BDF8",
              "#A16207",
              "#6366F1",
              "#FBBF24",
              "#F97316",
              "#64748B",
              "#C084FC",
              "#0284C7",
              "#DDD6FE",
              "#FCD34D",
              "#2563EB",
              "#9333EA",
              "#FB923C",
              "#94A3B8",
              "#E879F9",
              "#60A5FA",
              "#92400E",
              "#6D28D9",
              "#475569",
              "#F5D0FE"
            ]
          },
          "legend": {
            "orient": "bottom",
            "columns": 4,
            "symbolLimit": 30
          }
        },
        "tooltip": [
          { "field": "state", "type": "nominal", "title": "State" },
          { "field": "district", "type": "nominal", "title": "District" },
          { "field": "district_code", "type": "nominal", "title": "district_code" },
          { "field": "flood_years", "type": "quantitative", "format": ".0f", "title": "Flood years recorded" },
          { "field": "total_years", "type": "quantitative", "format": ".0f", "title": "Years observed" },
          { "field": "flood_frequency_percent", "type": "quantitative", "format": ".1f", "title": "Flood frequency (%)" }
        ]
      }
    }
  ],
  "resolve": {
    "scale": {
      "color": "independent"
    }
  },
  "config": {
    "background": "#dbeafe",
    "view": { "stroke": null, "fill": "#dbeafe" },
    "legend": {
      "labelFont": "Inter, Arial",
      "titleFont": "Inter, Arial",
      "labelColor": "#334155",
      "titleColor": "#0f172a",
      "orient": "bottom",
      "symbolStrokeColor": "#ffffff",
      "symbolStrokeWidth": 1
    },
    "title": {
      "font": "Inter, Arial",
      "fontSize": 16,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#0f172a",
      "subtitleFont": "Inter, Arial",
      "subtitleColor": "#64748b",
      "subtitleFontSize": 12
    }
  }
}
